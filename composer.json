{
    "name": "lizzyman04/fluxor-php",
    "description": "Fluxor PHP Framework - Skeleton project for new applications",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Arlindo Augusto",
            "email": "admin@tudocomlizzyman.com",
            "homepage": "https://lizzyman04.omeu.space"
        }
    ],
    "require": {
        "php": "^8.1",
        "lizzyman04/fluxor": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "classmap": [
            "Installer.php"
        ]
    },
    "scripts": {
        "post-create-project-cmd": [
            "FluxorInstaller\\Installer::postCreateProject"
        ],
        "serve": "php -S localhost:8000 -t public",
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "version": "1.0.0"
}